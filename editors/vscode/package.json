{
  "name": "rumoca-modelica",
  "displayName": "Rumoca Modelica",
  "description": "Modelica language support powered by rumoca-lsp",
  "version": "0.8.12",
  "publisher": "JamesGoppert",
  "repository": {
    "type": "git",
    "url": "https://github.com/climamind/rumoca"
  },
  "homepage": "https://github.com/climamind/rumoca#readme",
  "bugs": {
    "url": "https://github.com/climamind/rumoca/issues"
  },
  "license": "Apache-2.0",
  "icon": "icons/rumoca.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Notebooks"
  ],
  "keywords": [
    "modelica",
    "simulation",
    "dae",
    "modeling",
    "jupyter",
    "notebook"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:modelica",
    "onNotebook:jupyter-notebook",
    "onCommand:rumoca.openSettingsMenu",
    "onCommand:rumoca.renderTemplate",
    "onCommand:rumoca.simulateModel",
    "onCommand:rumoca.openSimulationSettings",
    "onCommand:rumoca.openTemplateSettings"
  ],
  "contributes": {
    "languages": [
      {
        "id": "modelica",
        "aliases": [
          "Modelica",
          "modelica"
        ],
        "extensions": [
          ".mo"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "modelica",
        "scopeName": "source.modelica",
        "path": "./syntaxes/modelica.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.modelica": "modelica"
        }
      },
      {
        "scopeName": "source.modelica.injection",
        "path": "./syntaxes/modelica-injection.tmLanguage.json",
        "injectTo": [
          "source.python"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.modelica": "modelica"
        }
      }
    ],
    "notebookRenderer": [],
    "configuration": {
      "type": "object",
      "title": "Rumoca Modelica",
      "properties": {
        "rumoca.serverPath": {
          "type": "string",
          "default": "",
          "description": "Path to the rumoca-lsp executable. If empty, will search in PATH."
        },
        "rumoca.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the language server."
        },
        "rumoca.debug": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging for the extension and language server."
        },
        "rumoca.useSystemServer": {
          "type": "boolean",
          "default": false,
          "description": "Use system-installed rumoca-lsp instead of the bundled binary. Enable this if you want to use a custom build or a different version."
        },
        "rumoca.sourceRootPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "List of directories containing Modelica source roots (for example ModelicaStandardLibrary). These are added to MODELICAPATH for import resolution."
        },
        "rumoca.collapseAnnotations": {
          "type": "boolean",
          "default": true,
          "description": "Collapse single-line annotation contents by default, showing 'annotation(...)' instead of the full content. Click on the annotation to expand."
        },
        "rumoca.simulation.model": {
          "type": "string",
          "default": "",
          "description": "Optional simulation model override. If empty, the extension infers the first model/block/class from the active file."
        },
        "rumoca.simulation.tEnd": {
          "type": "number",
          "default": 10,
          "minimum": 0.000001,
          "description": "Simulation end time passed to `rumoca simulate --t-end`."
        },
        "rumoca.simulation.dt": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Optional fixed output step for simulation. Set to 0 for automatic step selection."
        },
        "rumoca.simulation.solver": {
          "type": "string",
          "enum": [
            "auto",
            "bdf",
            "rk-like"
          ],
          "default": "auto",
          "description": "Solver mode passed to `rumoca simulate --solver`."
        },
        "rumoca.simulation.outputDir": {
          "type": "string",
          "default": "",
          "description": "Directory for generated simulation HTML reports. If empty, uses the system temp directory."
        }
      }
    },
    "configurationDefaults": {
      "[modelica]": {
        "editor.inlayHints.enabled": "on",
        "editor.codeLens": true
      }
    },
    "commands": [
      {
        "command": "rumoca.simulateModel",
        "title": "Simulate Current Modelica File",
        "shortTitle": "Simulate",
        "category": "Rumoca",
        "icon": {
          "light": "icons/simulate-light.svg",
          "dark": "icons/simulate-dark.svg"
        }
      },
      {
        "command": "rumoca.openSimulationSettings",
        "title": "Open Simulation Settings",
        "shortTitle": "Simulation Settings",
        "category": "Rumoca",
        "icon": {
          "light": "icons/settings-light.svg",
          "dark": "icons/settings-dark.svg"
        }
      },
      {
        "command": "rumoca.renderTemplate",
        "title": "Render Codegen Template",
        "shortTitle": "Render Template",
        "category": "Rumoca",
        "icon": {
          "light": "icons/template-light.svg",
          "dark": "icons/template-dark.svg"
        }
      },
      {
        "command": "rumoca.openTemplateSettings",
        "title": "Open Template Settings",
        "shortTitle": "Template Settings",
        "category": "Rumoca",
        "icon": {
          "light": "icons/settings-light.svg",
          "dark": "icons/settings-dark.svg"
        }
      },
      {
        "command": "rumoca.openSettingsMenu",
        "title": "Open Rumoca Settings",
        "shortTitle": "Settings",
        "category": "Rumoca",
        "icon": {
          "light": "icons/settings-light.svg",
          "dark": "icons/settings-dark.svg"
        }
      },
      {
        "command": "rumoca.toggleAnnotation",
        "title": "Toggle Annotation Expansion",
        "category": "Rumoca"
      },
      {
        "command": "rumoca.expandAllAnnotations",
        "title": "Expand All Annotations",
        "category": "Rumoca"
      },
      {
        "command": "rumoca.collapseAllAnnotations",
        "title": "Collapse All Annotations",
        "category": "Rumoca"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "rumoca.renderTemplate",
          "when": "editorLangId == modelica",
          "group": "navigation"
        },
        {
          "command": "rumoca.openSettingsMenu",
          "when": "editorLangId == modelica",
          "group": "navigation"
        }
      ],
      "editor/title/run": [
        {
          "command": "rumoca.simulateModel",
          "when": "editorLangId == modelica",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "rumoca.toggleAnnotation",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "editorTextFocus && editorLangId == modelica"
      },
      {
        "command": "rumoca.simulateModel",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r",
        "when": "editorTextFocus && editorLangId == modelica"
      }
    ]
  },
  "scripts": {
    "vendor-webview-assets": "node ./scripts/vendor-webview-assets.mjs",
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "npm run vendor-webview-assets && esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "compile": "tsc -p ./",
    "test": "npm run vendor-webview-assets && npm run compile && node --test tests/*.test.mjs",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "npm run esbuild-base -- --minify && npx @vscode/vsce package --no-dependencies --no-yarn"
  },
  "dependencies": {
    "three": "^0.160.0",
    "uplot": "^1.6.32",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "typescript": "^5.0.0"
  },
  "overrides": {
    "@vscode/vsce": {
      "glob": "^13.0.0"
    }
  }
}

