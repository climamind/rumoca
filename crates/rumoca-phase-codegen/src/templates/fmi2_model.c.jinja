FMI2_EXPORT fmi2Status fmi2SetContinuousStates(
    fmi2Component c,
    const fmi2Real x[], size_t nx)
{
    ModelInstance* m = (ModelInstance*)c;
    if (nx != N_STATES) return fmi2Error;

    memcpy(m->x, x, nx * sizeof(fmi2Real));
    m->dirty_values = 1;
    return fmi2OK;
