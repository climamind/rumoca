FMI2_EXPORT fmi2Status fmi2GetDerivatives(
    fmi2Component c,
    fmi2Real derivatives[], size_t nx)
{
    ModelInstance* m = (ModelInstance*)c;
    if (nx != N_DERIVATIVES) return fmi2Error;

    if (m->dirty_values) {
        compute_derivatives(m);
    }

    memcpy(derivatives, m->xdot, nx * sizeof(fmi2Real));
    return fmi2OK;
}

FMI2_EXPORT fmi2Status fmi2GetEventIndicators(
    fmi2Component c,
    fmi2Real eventIndicators[], size_t ni)
{
    ModelInstance* m = (ModelInstance*)c;
    if (ni != N_EVENT_INDICATORS) return fmi2Error;

    compute_event_indicators(m);
    memcpy(eventIndicators, m->event_indicators, ni * sizeof(fmi2Real));
    return fmi2OK;
}

FMI2_EXPORT fmi2Status fmi2EnterEventMode(fmi2Component c) {
    ModelInstance* m = (ModelInstance*)c;
    m->state = modelEventMode;
    m->is_new_event_iteration = 1;
    return fmi2OK;
}

FMI2_EXPORT fmi2Status fmi2NewDiscreteStates(fmi2Component c, fmi2EventInfo* eventInfo) {
    ModelInstance* m = (ModelInstance*)c;

    /* Save pre-values before discrete update */
    memcpy(m->pre_z, m->z, sizeof(m->z));
    memcpy(m->pre_m, m->m, sizeof(m->m));

    /* Evaluate discrete update equations */
    compute_discrete_updates(m);

    eventInfo->newDiscreteStatesNeeded = 0;
    eventInfo->terminateSimulation = 0;
    eventInfo->nominalsOfContinuousStatesChanged = 0;
    eventInfo->valuesOfContinuousStatesChanged = 0;

{% if dae.scheduled_time_events | default([]) | length > 0 %}
    /* Scheduled time events */
    {
        static const double scheduled_events[] = {
{% for t_event in dae.scheduled_time_events | default([]) %}
            {{ t_event }}{{ "," if not loop.last else "" }}
{% endfor %}
        };
        static const int n_scheduled = {{ dae.scheduled_time_events | default([]) | length }};
        eventInfo->nextEventTimeDefined = 0;
        for (int i = 0; i < n_scheduled; i++) {
            if (scheduled_events[i] > m->time + 1.0e-15) {
                eventInfo->nextEventTimeDefined = 1;
                eventInfo->nextEventTime = scheduled_events[i];
                break;
            }
        }
    }
{% else %}
    eventInfo->nextEventTimeDefined = 0;
    eventInfo->nextEventTime = 0.0;
{% endif %}

    m->is_new_event_iteration = 0;
    m->dirty_values = 1;
    return fmi2OK;
}

FMI2_EXPORT fmi2Status fmi2EnterContinuousTimeMode(fmi2Component c) {
    ModelInstance* m = (ModelInstance*)c;
    m->state = modelContinuousTimeMode;

    /* Save event indicators for zero-crossing detection */
    compute_event_indicators(m);
    memcpy(m->event_indicators_prev, m->event_indicators, sizeof(m->event_indicators));

    return fmi2OK;
}

FMI2_EXPORT fmi2Status fmi2CompletedIntegratorStep(
    fmi2Component c,
    fmi2Boolean   noSetFMUStatePriorToCurrentPoint,
    fmi2Boolean*  enterEventMode,
    fmi2Boolean*  terminateSimulation)
{
    (void)noSetFMUStatePriorToCurrentPoint;
    ModelInstance* m = (ModelInstance*)c;

    *enterEventMode = 0;
    *terminateSimulation = 0;

#if N_EVENT_INDICATORS > 0
    /* Check for zero-crossings in event indicators */
    compute_event_indicators(m);
    for (int i = 0; i < N_EVENT_INDICATORS; i++) {
        if (m->event_indicators[i] * m->event_indicators_prev[i] < 0.0) {
            *enterEventMode = 1;
            break;
        }
    }
    memcpy(m->event_indicators_prev, m->event_indicators, sizeof(m->event_indicators));
#else
    (void)m;
#endif

    return fmi2OK;
}

