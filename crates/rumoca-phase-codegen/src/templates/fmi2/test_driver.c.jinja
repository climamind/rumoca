{#- FMI 2.0 test driver — standalone CSV simulation.

    Generates a main() that drives the FMI2 model and outputs CSV.
    Compile together with the FMI2 model C source:
      cc -o test model.c test_driver.c -lm && ./test > trace.csv
-#}
{% set cfg = {"prefix": "", "power": "pow", "and_op": "&&", "or_op": "||", "not_op": "!", "true_val": "1", "false_val": "0", "if_style": "ternary", "subscript_underscore": true} %}
{#- Macro: compute total scalar size of a variable map -#}
{% macro var_size(vars) -%}
{%- set ns = namespace(total=0) -%}
{%- for name, var in vars | items -%}
{%- if var.dims -%}
{%- set ns.total = ns.total + var.dims | product -%}
{%- else -%}
{%- set ns.total = ns.total + 1 -%}
{%- endif -%}
{%- endfor -%}
{{ ns.total }}
{%- endmacro %}
{%- set n_x = var_size(dae.x) | trim | int -%}
{%- set n_y = var_size(dae.y) | trim | int -%}
{%- set n_u = var_size(dae.u) | trim | int -%}
{%- set n_w = var_size(dae.w) | trim | int -%}
/**
 * FMI 2.0 Test Driver — Generated by Rumoca
 *
 * Compile together with the FMI2 model source:
 *   cc -o test {{ model_name }}.c {{ model_name }}_driver.c -lm
 *   ./test --t-end 1.0 --dt 0.001 > trace.csv
 */

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

/* FMI2 types and function declarations (match fmi2/model.c.jinja) */
typedef unsigned int fmi2ValueReference;
typedef double       fmi2Real;
typedef int          fmi2Integer;
typedef int          fmi2Boolean;
typedef const char*  fmi2String;
typedef void*        fmi2Component;
typedef void*        fmi2ComponentEnvironment;

typedef enum { fmi2OK, fmi2Warning, fmi2Discard, fmi2Error, fmi2Fatal, fmi2Pending } fmi2Status;
typedef enum { fmi2ModelExchange, fmi2CoSimulation } fmi2Type;

typedef void  (*fmi2CallbackLogger)(fmi2ComponentEnvironment, fmi2String, fmi2Status, fmi2String, fmi2String, ...);
typedef void* (*fmi2CallbackAllocateMemory)(size_t, size_t);
typedef void  (*fmi2CallbackFreeMemory)(void*);
typedef void  (*fmi2StepFinished)(fmi2ComponentEnvironment, fmi2Status);

typedef struct {
    fmi2CallbackLogger         logger;
    fmi2CallbackAllocateMemory allocateMemory;
    fmi2CallbackFreeMemory     freeMemory;
    fmi2StepFinished           stepFinished;
    fmi2ComponentEnvironment   componentEnvironment;
} fmi2CallbackFunctions;

typedef struct {
    fmi2Boolean newDiscreteStatesNeeded;
    fmi2Boolean terminateSimulation;
    fmi2Boolean nominalsOfContinuousStatesChanged;
    fmi2Boolean valuesOfContinuousStatesChanged;
    fmi2Boolean nextEventTimeDefined;
    fmi2Real    nextEventTime;
} fmi2EventInfo;

/* FMI2 API declarations */
extern fmi2Component fmi2Instantiate(fmi2String, fmi2Type, fmi2String, fmi2String, const fmi2CallbackFunctions*, fmi2Boolean, fmi2Boolean);
extern void fmi2FreeInstance(fmi2Component);
extern fmi2Status fmi2SetupExperiment(fmi2Component, fmi2Boolean, fmi2Real, fmi2Real, fmi2Boolean, fmi2Real);
extern fmi2Status fmi2EnterInitializationMode(fmi2Component);
extern fmi2Status fmi2ExitInitializationMode(fmi2Component);
extern fmi2Status fmi2SetTime(fmi2Component, fmi2Real);
extern fmi2Status fmi2SetContinuousStates(fmi2Component, const fmi2Real[], size_t);
extern fmi2Status fmi2GetContinuousStates(fmi2Component, fmi2Real[], size_t);
extern fmi2Status fmi2GetDerivatives(fmi2Component, fmi2Real[], size_t);
extern fmi2Status fmi2GetReal(fmi2Component, const fmi2ValueReference[], size_t, fmi2Real[]);
extern fmi2Status fmi2EnterEventMode(fmi2Component);
extern fmi2Status fmi2NewDiscreteStates(fmi2Component, fmi2EventInfo*);
extern fmi2Status fmi2EnterContinuousTimeMode(fmi2Component);
extern fmi2Status fmi2CompletedIntegratorStep(fmi2Component, fmi2Boolean, fmi2Boolean*, fmi2Boolean*);
extern fmi2Status fmi2Terminate(fmi2Component);

static void dummy_logger(fmi2ComponentEnvironment env, fmi2String inst, fmi2Status status, fmi2String cat, fmi2String msg, ...) {
    (void)env; (void)inst; (void)status; (void)cat; (void)msg;
}

int main(int argc, char* argv[]) {
    double t_end = 1.0;
    double dt = 0.001;

    for (int i = 1; i < argc; i++) {
        if (strcmp(argv[i], "--t-end") == 0 && i + 1 < argc)
            t_end = atof(argv[++i]);
        else if (strcmp(argv[i], "--dt") == 0 && i + 1 < argc)
            dt = atof(argv[++i]);
    }

    int n_steps = (int)(t_end / dt);

    fmi2CallbackFunctions callbacks = {
        dummy_logger, calloc, free, NULL, NULL
    };

    fmi2Component comp = fmi2Instantiate(
        "test", fmi2ModelExchange,
        "{{ model_name }}-rumoca", "",
        &callbacks, 0, 0);
    if (!comp) {
        fprintf(stderr, "fmi2Instantiate failed\n");
        return 1;
    }

    fmi2SetupExperiment(comp, 0, 0.0, 0.0, 1, t_end);
    fmi2EnterInitializationMode(comp);
    fmi2ExitInitializationMode(comp);

    {
        fmi2EventInfo ei;
        fmi2NewDiscreteStates(comp, &ei);
    }
    fmi2EnterContinuousTimeMode(comp);

    /* CSV header */
    printf("time");
{% for name, var in dae.x | items %}
{% if var.dims %}
{% set sz = var.dims | product %}
{% for i in range(sz) %}
    printf(",{{ name }}[{{ i + 1 }}]");
{% endfor %}
{% else %}
    printf(",{{ name }}");
{% endif %}
{% endfor %}
    printf("\n");

    double x[{{ n_x }} > 0 ? {{ n_x }} : 1];
    double xdot[{{ n_x }} > 0 ? {{ n_x }} : 1];

{% if n_x > 0 %}
    fmi2GetContinuousStates(comp, x, {{ n_x }});
{% endif %}

    for (int step = 0; step <= n_steps; step++) {
        double t = step * dt;
        fmi2SetTime(comp, t);
{% if n_x > 0 %}
        fmi2SetContinuousStates(comp, x, {{ n_x }});
        fmi2GetDerivatives(comp, xdot, {{ n_x }});
{% endif %}

        /* Print state */
        printf("%.10g", t);
{% set ns_vr = namespace(offset=0) %}
{% for name, var in dae.x | items %}
{% if var.dims %}
{% set sz = var.dims | product %}
{% for i in range(sz) %}
        {
            fmi2ValueReference vr = {{ ns_vr.offset }};
            fmi2Real val;
            fmi2GetReal(comp, &vr, 1, &val);
            printf(",%.10g", val);
        }
{% set ns_vr.offset = ns_vr.offset + 1 %}
{% endfor %}
{% else %}
        {
            fmi2ValueReference vr = {{ ns_vr.offset }};
            fmi2Real val;
            fmi2GetReal(comp, &vr, 1, &val);
            printf(",%.10g", val);
        }
{% set ns_vr.offset = ns_vr.offset + 1 %}
{% endif %}
{% endfor %}
        printf("\n");

{% if n_x > 0 %}
        /* Euler step */
        for (int i = 0; i < {{ n_x }}; i++)
            x[i] += dt * xdot[i];
{% endif %}

        /* Check events */
        {
            fmi2Boolean enterEvent = 0, terminate = 0;
            fmi2CompletedIntegratorStep(comp, 1, &enterEvent, &terminate);
            if (terminate) break;
            if (enterEvent) {
                fmi2EnterEventMode(comp);
                fmi2EventInfo ei;
                fmi2NewDiscreteStates(comp, &ei);
                fmi2EnterContinuousTimeMode(comp);
                if (ei.terminateSimulation) break;
            }
        }
    }

    fmi2Terminate(comp);
    fmi2FreeInstance(comp);
    return 0;
}
