static void compute_algebraics(ModelInstance* m) {
{% if dae.y | length > 0 or dae.w | length > 0 %}
    const double t = m->time;
    const double time = m->time;
    (void)t; (void)time;

    /* Unpack states + derivative aliases (pre_ = current value for continuous vars) */
{{ unpack_vars(dae.x, "m->x", der_prefix=true, pre_array="m->x") }}
    /* Unpack inputs */
{{ unpack_vars(dae.u, "m->u", pre_array="m->u") }}
    /* Unpack parameters */
{{ unpack_vars(dae.p, "m->p") }}
    /* Unpack constants */
{{ unpack_vars(dae.constants, "m->constants") }}
    /* Unpack discrete reals (with pre-values for pre() macro) */
{{ unpack_vars(dae.z, "m->z", pre_array="m->pre_z") }}
    /* Unpack discrete valued (with pre-values for pre() macro) */
{{ unpack_vars(dae.m, "m->m", pre_array="m->pre_m") }}
    /* Mutable local aliases for algebraic variables (evaluation order matters) */
{{ unpack_vars(dae.y, "m->y", mutable=true, pre_array="m->y") }}
    /* Mutable local aliases for output variables */
{{ unpack_vars(dae.w, "m->w", mutable=true, pre_array="m->w") }}

    /* Evaluate output variables first (algebraics may depend on them) */
{% set ns_out = namespace(offset=0) %}
{% for name, var in dae.w | items %}
{% if var.dims %}
{% set sz = var.dims | product %}
{% for i in range(sz) %}
    {{ name | sanitize }}_{{ i + 1 }} = {{ alg_rhs_for_var(name ~ "[" ~ (i + 1) ~ "]", dae.f_x, cfg) }};
    m->w[{{ ns_out.offset }}] = {{ name | sanitize }}_{{ i + 1 }};  /* {{ name }}[{{ i + 1 }}] */
{% set ns_out.offset = ns_out.offset + 1 %}
{% endfor %}
{% else %}
    {{ name | sanitize }} = {{ alg_rhs_for_var(name, dae.f_x, cfg) }};
    m->w[{{ ns_out.offset }}] = {{ name | sanitize }};  /* {{ name }} */
{% set ns_out.offset = ns_out.offset + 1 %}
{% endif %}
{% endfor %}

    /* Evaluate algebraic variables (explicit form extracted from residual 0 = y - rhs) */
{% set ns_alg = namespace(offset=0) %}
{% for name, var in dae.y | items %}
{% if var.dims %}
{% set sz = var.dims | product %}
{% for i in range(sz) %}
    {{ name | sanitize }}_{{ i + 1 }} = {{ alg_rhs_for_var(name ~ "[" ~ (i + 1) ~ "]", dae.f_x, cfg) }};
    m->y[{{ ns_alg.offset }}] = {{ name | sanitize }}_{{ i + 1 }};  /* {{ name }}[{{ i + 1 }}] */
{% set ns_alg.offset = ns_alg.offset + 1 %}
{% endfor %}
{% else %}
    {{ name | sanitize }} = {{ alg_rhs_for_var(name, dae.f_x, cfg) }};
    m->y[{{ ns_alg.offset }}] = {{ name | sanitize }};  /* {{ name }} */
{% set ns_alg.offset = ns_alg.offset + 1 %}
{% endif %}
{% endfor %}
{% else %}
    (void)m;
{% endif %}
}

/* =========================================================================
 * Compute derivatives (f_x equations)
 * ========================================================================= */
static void compute_derivatives(ModelInstance* m) {
    /* Compute algebraics first (derivatives may depend on them) */
    compute_algebraics(m);

    /* Unpack local aliases for readability */
    const double t = m->time;
    const double time = m->time;
    (void)t; (void)time;

{{ unpack_vars(dae.x, "m->x", der_prefix=true, pre_array="m->x") }}
{{ unpack_vars(dae.y, "m->y", pre_array="m->y") }}
{{ unpack_vars(dae.w, "m->w", pre_array="m->w") }}
{{ unpack_vars(dae.u, "m->u", pre_array="m->u") }}
{{ unpack_vars(dae.p, "m->p") }}
{{ unpack_vars(dae.constants, "m->constants") }}
{{ unpack_vars(dae.z, "m->z", pre_array="m->pre_z") }}
{{ unpack_vars(dae.m, "m->m", pre_array="m->pre_m") }}

    /* Evaluate derivatives (explicit form extracted from residual 0 = der(x) - rhs) */
{% set ns_xdot = namespace(offset=0) %}
{% for name, var in dae.x | items %}
{% if var.dims %}
{% set sz = var.dims | product %}
{% for i in range(sz) %}
    m->xdot[{{ ns_xdot.offset }}] = {{ ode_rhs_for_state(name ~ "[" ~ (i + 1) ~ "]", dae.f_x, cfg) }};  /* der({{ name }}[{{ i + 1 }}]) */
{% set ns_xdot.offset = ns_xdot.offset + 1 %}
{% endfor %}
{% else %}
    m->xdot[{{ ns_xdot.offset }}] = {{ ode_rhs_for_state(name, dae.f_x, cfg) }};  /* der({{ name }}) */
{% set ns_xdot.offset = ns_xdot.offset + 1 %}
{% endif %}
{% endfor %}

    /* Re-compute algebraics after derivatives (resolves derivative aliases) */
    compute_algebraics(m);

    m->dirty_values = 0;
}

