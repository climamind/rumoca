/* =========================================================================
 * FMI 3.0 API — Partial Derivatives (not supported)
 * ========================================================================= */

FMI3_EXPORT fmi3Status fmi3GetDirectionalDerivative(
    fmi3Instance instance,
    const fmi3ValueReference unknowns[], size_t nUnknowns,
    const fmi3ValueReference knowns[], size_t nKnowns,
    const fmi3Float64 seed[], size_t nSeed,
    fmi3Float64 sensitivity[], size_t nSensitivity)
{
    ModelInstance* m = (ModelInstance*)instance;
    (void)nSeed;

    /* Compute baseline derivatives */
    compute_derivatives(m);
    fmi3Float64 f0[N_DERIVATIVES > 0 ? N_DERIVATIVES : 1];
    memcpy(f0, m->xdot, N_DERIVATIVES * sizeof(fmi3Float64));

    /* Zero output sensitivities */
    for (size_t si = 0; si < nSensitivity; si++) sensitivity[si] = 0.0;

    /* Finite-difference: for each known VR (may be array), perturb each scalar
       element and accumulate the Jacobian-vector product into sensitivities. */
    size_t seed_idx = 0;
    for (size_t j = 0; j < nKnowns; j++) {
        int k_count = vr_scalar_count(knowns[j]);
        fmi3Float64 orig_vals[N_REALS > 0 ? N_REALS : 1];
        int dummy;
        get_float64_by_vr(m, knowns[j], orig_vals, &dummy);

        for (int ke = 0; ke < k_count; ke++) {
            if (seed[seed_idx + ke] == 0.0) continue;

            const double eps = 1.0e-8;
            double h = eps * fmax(fabs(orig_vals[ke]), 1.0);

            /* Perturb single scalar element */
            fmi3Float64 perturbed[N_REALS > 0 ? N_REALS : 1];
            memcpy(perturbed, orig_vals, k_count * sizeof(fmi3Float64));
            perturbed[ke] += h;
            set_float64_by_vr(m, knowns[j], perturbed, &dummy);
            compute_derivatives(m);

            /* Accumulate (f_perturbed - f0) / h * seed into sensitivities */
            size_t sens_idx = 0;
            for (size_t i = 0; i < nUnknowns; i++) {
                int u_count = vr_scalar_count(unknowns[i]);
                int u_offset = xdot_flat_offset_for_vr(unknowns[i]);
                if (u_offset >= 0) {
                    for (int ue = 0; ue < u_count; ue++) {
                        sensitivity[sens_idx + ue] +=
                            ((m->xdot[u_offset + ue] - f0[u_offset + ue]) / h) * seed[seed_idx + ke];
                    }
                }
                sens_idx += u_count;
            }

            /* Restore */
            set_float64_by_vr(m, knowns[j], orig_vals, &dummy);
        }
        seed_idx += k_count;
    }

    /* Restore clean derivatives */
    m->dirty_values = 1;
    compute_derivatives(m);

    return fmi3OK;
}

FMI3_EXPORT fmi3Status fmi3GetAdjointDerivative(
    fmi3Instance instance,
    const fmi3ValueReference unknowns[], size_t nUnknowns,
    const fmi3ValueReference knowns[], size_t nKnowns,
    const fmi3Float64 seed[], size_t nSeed,
    fmi3Float64 sensitivity[], size_t nSensitivity)
{
    /* Adjoint derivative via finite-difference transpose:
     * sensitivity_j += sum_i (df_i/dx_j) * seed_i
     * This is the transpose of the directional derivative. */
    ModelInstance* m = (ModelInstance*)instance;
    (void)nSeed;

    /* Compute baseline derivatives */
    compute_derivatives(m);
    fmi3Float64 f0[N_DERIVATIVES > 0 ? N_DERIVATIVES : 1];
    memcpy(f0, m->xdot, N_DERIVATIVES * sizeof(fmi3Float64));

    /* Zero output sensitivities */
    for (size_t si = 0; si < nSensitivity; si++) sensitivity[si] = 0.0;

    /* For each known VR (output column), perturb each scalar element
       and accumulate seed^T * (df/dx) into sensitivities. */
    size_t sens_idx = 0;
    for (size_t j = 0; j < nKnowns; j++) {
        int k_count = vr_scalar_count(knowns[j]);
        fmi3Float64 orig_vals[N_REALS > 0 ? N_REALS : 1];
        int dummy;
        get_float64_by_vr(m, knowns[j], orig_vals, &dummy);

        for (int ke = 0; ke < k_count; ke++) {
            const double eps = 1.0e-8;
            double h = eps * fmax(fabs(orig_vals[ke]), 1.0);

            /* Perturb single scalar element */
            fmi3Float64 perturbed[N_REALS > 0 ? N_REALS : 1];
            memcpy(perturbed, orig_vals, k_count * sizeof(fmi3Float64));
            perturbed[ke] += h;
            set_float64_by_vr(m, knowns[j], perturbed, &dummy);
            compute_derivatives(m);

            /* Accumulate seed^T * column_j of Jacobian:
               sensitivity[j*k_count + ke] += sum_i seed_i * (f_perturbed_i - f0_i) / h */
            size_t seed_idx = 0;
            for (size_t i = 0; i < nUnknowns; i++) {
                int u_count = vr_scalar_count(unknowns[i]);
                int u_offset = xdot_flat_offset_for_vr(unknowns[i]);
                if (u_offset >= 0) {
                    for (int ue = 0; ue < u_count; ue++) {
                        sensitivity[sens_idx + ke] +=
                            seed[seed_idx + ue] * ((m->xdot[u_offset + ue] - f0[u_offset + ue]) / h);
                    }
                }
                seed_idx += u_count;
            }

            /* Restore */
            set_float64_by_vr(m, knowns[j], orig_vals, &dummy);
        }
        sens_idx += k_count;
    }

    /* Restore clean derivatives */
    m->dirty_values = 1;
    compute_derivatives(m);

    return fmi3OK;
}

/* =========================================================================
 * FMI 3.0 API — Co-Simulation (§4.2)
 *
 * Built-in forward Euler integrator for standalone Co-Simulation use.
 * For production accuracy, prefer Model Exchange with an external solver.
 * ========================================================================= */

FMI3_EXPORT fmi3Status fmi3DoStep(
    fmi3Instance instance,
    fmi3Float64  currentCommunicationPoint,
    fmi3Float64  communicationStepSize,
    fmi3Boolean  noSetFMUStatePriorToCurrentPoint,
    fmi3Boolean* eventHandlingNeeded,
    fmi3Boolean* terminateSimulation,
    fmi3Boolean* earlyReturn,
    fmi3Float64* lastSuccessfulTime)
{
    (void)noSetFMUStatePriorToCurrentPoint;
    ModelInstance* m = (ModelInstance*)instance;

    /* Simple forward Euler with sub-stepping */
    const double dt_max = communicationStepSize / 10.0;
    double t = currentCommunicationPoint;
    const double t_end = currentCommunicationPoint + communicationStepSize;
    fmi3IntermediateUpdateCallback cb = (fmi3IntermediateUpdateCallback)m->intermediateUpdate;

    while (t < t_end - 1.0e-15) {
        double dt = t_end - t;
        if (dt > dt_max) dt = dt_max;

        m->time = t;
        m->dirty_values = 1;
        compute_derivatives(m);

#if N_STATES > 0
        for (int i = 0; i < N_STATES; i++) {
            m->x[i] += dt * m->xdot[i];
        }
#endif

        t += dt;

        /* Intermediate update callback (FMI 3.0 §4.2.3) */
        if (cb) {
            fmi3Boolean earlyReturnRequested = 0;
            fmi3Float64 earlyReturnTime = t;
            cb(m->instance_environment, t, 0, 0, 1, 1,
               m->early_return_allowed, &earlyReturnRequested, &earlyReturnTime);
            if (earlyReturnRequested && m->early_return_allowed) {
                m->time = earlyReturnTime;
                m->dirty_values = 1;
                compute_derivatives(m);
                *eventHandlingNeeded = 0;
                *terminateSimulation = 0;
                *earlyReturn = 1;
                *lastSuccessfulTime = earlyReturnTime;
                return fmi3OK;
            }
        }
    }

    m->time = t_end;
    m->dirty_values = 1;
    compute_derivatives(m);

    *eventHandlingNeeded = 0;
    *terminateSimulation = 0;
    *earlyReturn = 0;
    *lastSuccessfulTime = t_end;

    return fmi3OK;
}

