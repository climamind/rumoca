FMI3_EXPORT const char* fmi3GetVersion(void) {
    return "3.0";
}

FMI3_EXPORT fmi3Instance fmi3InstantiateModelExchange(
    fmi3String                 instanceName,
    fmi3String                 instantiationToken,
    fmi3String                 resourcePath,
    fmi3Boolean                visible,
    fmi3Boolean                loggingOn,
    fmi3InstanceEnvironment    instanceEnvironment,
    fmi3LogMessageCallback     logMessage)
{
    (void)resourcePath;
    (void)visible;
    (void)loggingOn;
    (void)instanceEnvironment;
    (void)logMessage;

    if (strcmp(instantiationToken, MODEL_INSTANTIATION_TOKEN) != 0) {
        return NULL;
    }

    ModelInstance* m = (ModelInstance*)calloc(1, sizeof(ModelInstance));
    if (!m) return NULL;
    m->instance_name = instanceName;
    m->instantiation_token = instantiationToken;
    m->is_co_simulation = 0;
    m->state = modelInstantiated;

    initialize_defaults(m);

    return (fmi3Instance)m;
}

FMI3_EXPORT fmi3Instance fmi3InstantiateCoSimulation(
    fmi3String                 instanceName,
    fmi3String                 instantiationToken,
    fmi3String                 resourcePath,
    fmi3Boolean                visible,
    fmi3Boolean                loggingOn,
    fmi3Boolean                eventModeUsed,
    fmi3Boolean                earlyReturnAllowed,
    const fmi3ValueReference   requiredIntermediateVariables[],
    size_t                     nRequiredIntermediateVariables,
    fmi3InstanceEnvironment    instanceEnvironment,
    fmi3LogMessageCallback     logMessage,
    void*                      intermediateUpdate)
{
    (void)resourcePath;
    (void)visible;
    (void)loggingOn;
    (void)eventModeUsed;
    (void)requiredIntermediateVariables;
    (void)nRequiredIntermediateVariables;
    (void)logMessage;

    if (strcmp(instantiationToken, MODEL_INSTANTIATION_TOKEN) != 0) {
        return NULL;
    }

    ModelInstance* m = (ModelInstance*)calloc(1, sizeof(ModelInstance));
    if (!m) return NULL;
    m->instance_name = instanceName;
    m->instantiation_token = instantiationToken;
    m->is_co_simulation = 1;
    m->early_return_allowed = earlyReturnAllowed;
    m->instance_environment = instanceEnvironment;
    m->intermediateUpdate = (void*)intermediateUpdate;
    m->state = modelInstantiated;

    initialize_defaults(m);

    return (fmi3Instance)m;
}

FMI3_EXPORT void fmi3FreeInstance(fmi3Instance instance) {
    if (instance) {
        free(instance);
    }
}

FMI3_EXPORT fmi3Status fmi3EnterInitializationMode(
    fmi3Instance instance,
    fmi3Boolean  toleranceDefined,
    fmi3Float64  tolerance,
    fmi3Float64  startTime,
    fmi3Boolean  stopTimeDefined,
    fmi3Float64  stopTime)
{
    (void)toleranceDefined;
    (void)tolerance;
    (void)stopTimeDefined;
    (void)stopTime;

    ModelInstance* m = (ModelInstance*)instance;
    m->time = startTime;
    m->state = modelInitializationMode;
    return fmi3OK;
}

FMI3_EXPORT fmi3Status fmi3ExitInitializationMode(fmi3Instance instance) {
    ModelInstance* m = (ModelInstance*)instance;

    /* Compute initial derivatives and outputs */
    compute_derivatives(m);
    compute_event_indicators(m);
    memcpy(m->event_indicators_prev, m->event_indicators, sizeof(m->event_indicators));

    m->state = modelEventMode;
    return fmi3OK;
}

FMI3_EXPORT fmi3Status fmi3EnterConfigurationMode(fmi3Instance instance) {
    ModelInstance* m = (ModelInstance*)instance;
    m->state = modelConfigurationMode;
    return fmi3OK;
}

FMI3_EXPORT fmi3Status fmi3ExitConfigurationMode(fmi3Instance instance) {
    ModelInstance* m = (ModelInstance*)instance;
    m->state = modelInstantiated;
    m->dirty_values = 1;  /* Force recomputation after tunable parameter changes */
    return fmi3OK;
}

