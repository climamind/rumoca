/* Helper: get float64 values by value reference (native array: copies count elements) */
static fmi3Status get_float64_by_vr(const ModelInstance* m, fmi3ValueReference vr, fmi3Float64* values, int* count) {
#if NVAR_X > 0
    if (vr >= VR_X && vr < VR_X + NVAR_X) {
        int i = vr - VR_X;
        *count = x_var_count[i];
        memcpy(values, &m->x[x_flat_offset[i]], *count * sizeof(fmi3Float64));
        return fmi3OK;
    }
    if (vr >= VR_XDOT && vr < VR_XDOT + NVAR_X) {
        int i = vr - VR_XDOT;
        *count = x_var_count[i];
        memcpy(values, &m->xdot[x_flat_offset[i]], *count * sizeof(fmi3Float64));
        return fmi3OK;
    }
#endif
#if NVAR_Y > 0
    if (vr >= VR_Y && vr < VR_Y + NVAR_Y) {
        int i = vr - VR_Y;
        *count = y_var_count[i];
        memcpy(values, &m->y[y_flat_offset[i]], *count * sizeof(fmi3Float64));
        return fmi3OK;
    }
#endif
#if NVAR_U > 0
    if (vr >= VR_U && vr < VR_U + NVAR_U) {
        int i = vr - VR_U;
        *count = u_var_count[i];
        memcpy(values, &m->u[u_flat_offset[i]], *count * sizeof(fmi3Float64));
        return fmi3OK;
    }
#endif
#if NVAR_W > 0
    if (vr >= VR_W && vr < VR_W + NVAR_W) {
        int i = vr - VR_W;
        *count = w_var_count[i];
        memcpy(values, &m->w[w_flat_offset[i]], *count * sizeof(fmi3Float64));
        return fmi3OK;
    }
#endif
#if NVAR_P > 0
    if (vr >= VR_P && vr < VR_P + NVAR_P) {
        int i = vr - VR_P;
        *count = p_var_count[i];
        memcpy(values, &m->p[p_flat_offset[i]], *count * sizeof(fmi3Float64));
        return fmi3OK;
    }
#endif
#if NVAR_Z > 0
    if (vr >= VR_Z && vr < VR_Z + NVAR_Z) {
        int i = vr - VR_Z;
        *count = z_var_count[i];
        memcpy(values, &m->z[z_flat_offset[i]], *count * sizeof(fmi3Float64));
        return fmi3OK;
    }
#endif
#if NVAR_M > 0
    if (vr >= VR_M && vr < VR_M + NVAR_M) {
        int i = vr - VR_M;
        *count = m_var_count[i];
        memcpy(values, &m->m[m_flat_offset[i]], *count * sizeof(fmi3Float64));
        return fmi3OK;
    }
#endif
    if (vr >= VR_OBS && vr < VR_OBS + NVAR_OBS) {
        return get_native_observable_by_vr(m, vr, values, count);
    }
    *count = 0;
    return fmi3Error;
}

/* Helper: set float64 values by value reference (native array: copies count elements) */
static fmi3Status set_float64_by_vr(ModelInstance* m, fmi3ValueReference vr, const fmi3Float64* values, int* count) {
#if NVAR_X > 0
    if (vr >= VR_X && vr < VR_X + NVAR_X) {
        int i = vr - VR_X;
        *count = x_var_count[i];
        memcpy(&m->x[x_flat_offset[i]], values, *count * sizeof(fmi3Float64));
        m->dirty_values = 1;
        return fmi3OK;
    }
#endif
#if NVAR_U > 0
    if (vr >= VR_U && vr < VR_U + NVAR_U) {
        int i = vr - VR_U;
        *count = u_var_count[i];
        memcpy(&m->u[u_flat_offset[i]], values, *count * sizeof(fmi3Float64));
        m->dirty_values = 1;
        return fmi3OK;
    }
#endif
#if NVAR_P > 0
    if (vr >= VR_P && vr < VR_P + NVAR_P) {
        int i = vr - VR_P;
        *count = p_var_count[i];
        memcpy(&m->p[p_flat_offset[i]], values, *count * sizeof(fmi3Float64));
        m->dirty_values = 1;
        return fmi3OK;
    }
#endif
#if NVAR_Z > 0
    if (vr >= VR_Z && vr < VR_Z + NVAR_Z) {
        int i = vr - VR_Z;
        *count = z_var_count[i];
        memcpy(&m->z[z_flat_offset[i]], values, *count * sizeof(fmi3Float64));
        m->dirty_values = 1;
        return fmi3OK;
    }
#endif
    *count = 0;
    return fmi3Error;
}

/* Helper: get scalar count for a VR (used by directional derivatives) */
static int vr_scalar_count(fmi3ValueReference vr) {
#if NVAR_X > 0
    if (vr >= VR_X && vr < VR_X + NVAR_X) return x_var_count[vr - VR_X];
    if (vr >= VR_XDOT && vr < VR_XDOT + NVAR_X) return x_var_count[vr - VR_XDOT];
#endif
#if NVAR_Y > 0
    if (vr >= VR_Y && vr < VR_Y + NVAR_Y) return y_var_count[vr - VR_Y];
#endif
#if NVAR_U > 0
    if (vr >= VR_U && vr < VR_U + NVAR_U) return u_var_count[vr - VR_U];
#endif
#if NVAR_W > 0
    if (vr >= VR_W && vr < VR_W + NVAR_W) return w_var_count[vr - VR_W];
#endif
#if NVAR_P > 0
    if (vr >= VR_P && vr < VR_P + NVAR_P) return p_var_count[vr - VR_P];
#endif
#if NVAR_Z > 0
    if (vr >= VR_Z && vr < VR_Z + NVAR_Z) return z_var_count[vr - VR_Z];
#endif
#if NVAR_M > 0
    if (vr >= VR_M && vr < VR_M + NVAR_M) return m_var_count[vr - VR_M];
#endif
    if (vr >= VR_OBS && vr < VR_OBS + NVAR_OBS) return 1;
    return 0;
}

/* Helper: get flat offset for a derivative VR (used by directional derivatives) */
static int xdot_flat_offset_for_vr(fmi3ValueReference vr) {
#if NVAR_X > 0
    if (vr >= VR_XDOT && vr < VR_XDOT + NVAR_X) return x_flat_offset[vr - VR_XDOT];
#endif
    return -1;
}

