{
  "name": "rumoca-npm-tools",
  "private": true,
  "scripts": {
    "build": "node ./build.mjs --profile release --variant core",
    "build:pack": "node ./build.mjs --profile release --variant core --pack",
    "build:dev": "node ./build.mjs --profile dev --variant core",
    "build:dev:pack": "node ./build.mjs --profile dev --variant core --pack",
    "build:release:core": "node ./build.mjs --profile release --variant core",
    "build:release:core:pack": "node ./build.mjs --profile release --variant core --pack",
    "build:release:core:rayon": "node ./build.mjs --profile release --variant core --rayon",
    "build:release:core:rayon:pack": "node ./build.mjs --profile release --variant core --rayon --pack",
    "build:release:sim-diffsol": "node ./build.mjs --profile release --variant sim-diffsol",
    "build:release:sim-diffsol:pack": "node ./build.mjs --profile release --variant sim-diffsol --pack",
    "build:release:sim-rk45": "node ./build.mjs --profile release --variant sim-rk45",
    "build:release:sim-rk45:pack": "node ./build.mjs --profile release --variant sim-rk45 --pack",
    "build:release:full-web": "node ./build.mjs --profile release --variant full-web",
    "build:release:full-web:pack": "node ./build.mjs --profile release --variant full-web --pack",
    "build:release:full-web:rayon": "node ./build.mjs --profile release --variant full-web --rayon",
    "build:release:full-web:rayon:pack": "node ./build.mjs --profile release --variant full-web --rayon --pack",
    "build:dev:core": "node ./build.mjs --profile dev --variant core",
    "build:dev:core:pack": "node ./build.mjs --profile dev --variant core --pack",
    "build:dev:core:rayon": "node ./build.mjs --profile dev --variant core --rayon",
    "build:dev:core:rayon:pack": "node ./build.mjs --profile dev --variant core --rayon --pack",
    "build:dev:sim-diffsol": "node ./build.mjs --profile dev --variant sim-diffsol",
    "build:dev:sim-diffsol:pack": "node ./build.mjs --profile dev --variant sim-diffsol --pack",
    "build:dev:sim-rk45": "node ./build.mjs --profile dev --variant sim-rk45",
    "build:dev:sim-rk45:pack": "node ./build.mjs --profile dev --variant sim-rk45 --pack",
    "build:dev:full-web": "node ./build.mjs --profile dev --variant full-web",
    "build:dev:full-web:pack": "node ./build.mjs --profile dev --variant full-web --pack",
    "build:dev:full-web:rayon": "node ./build.mjs --profile dev --variant full-web --rayon",
    "build:dev:full-web:rayon:pack": "node ./build.mjs --profile dev --variant full-web --rayon --pack",
    "publish": "npm run publish:release:core",
    "publish:release:core": "npm run build:release:core && cd ../../pkg/release-core && npm publish",
    "publish:release:sim-diffsol": "npm run build:release:sim-diffsol && cd ../../pkg/release-sim-diffsol && npm publish",
    "publish:release:sim-rk45": "npm run build:release:sim-rk45 && cd ../../pkg/release-sim-rk45 && npm publish",
    "publish:release:full-web": "npm run build:release:full-web && cd ../../pkg/release-full-web && npm publish",
    "publish:release:core:dry-run": "npm run build:release:core && cd ../../pkg/release-core && npm publish --dry-run",
    "publish:release:sim-diffsol:dry-run": "npm run build:release:sim-diffsol && cd ../../pkg/release-sim-diffsol && npm publish --dry-run",
    "publish:release:sim-rk45:dry-run": "npm run build:release:sim-rk45 && cd ../../pkg/release-sim-rk45 && npm publish --dry-run",
    "publish:release:full-web:dry-run": "npm run build:release:full-web && cd ../../pkg/release-full-web && npm publish --dry-run"
  }
}
